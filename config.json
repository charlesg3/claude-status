{
  "project_name": "claude-status",
  "config_dir": "~/.config/claude-status",
  "state_dir": "/tmp",
  "log": {
    "file": "~/.local/share/claude-status/claude-status.log",
    "max_lines": 500
  },
  "notifications": {
    "terminal": {
      "enabled": true,
      "notification_threshold": 0
    },
    "sound": {
      "enabled": true,
      "volume": 0.7,
      "path": null,
      "notification_threshold": 30
    },
    "os": {
      "enabled": true,
      "notification_threshold": 30
    },
    "vim": {
      "enabled": true,
      "notification_threshold": 0
    }
  },
  "statusline": {
    "enabled": true,
    "layout": [
      "state", "directory", "branch", "git_status", "session_id",
      "spacer",
      "context", "cost", "duration"
    ],
    "icons": {
      "working":   "↻",
      "ready":     "●",
      "directory": "📁",
      "branch":    "🌿",
      "staged":    "+",
      "modified":  "*",
      "cost":      "💰",
      "duration":  "⏱️",
      "dot":       "●",
      "small_dot": "•"
    },
    "colors": {
      "working":       "#6FC1FF",
      "ready":         "#55B96D",
      "error":         "#C91614",
      "warning":       "#FFB86C",
      "branch":        "#B1B9F5",
      "dim":           "#676B79"
    }
  }
}
